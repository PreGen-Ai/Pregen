# Backend runtime
APP_NAME=PreGen Backend
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000
# Optional explicit frontend allowlist entries. Supports comma-separated origins
# and safely normalizes trailing slashes, for example:
# CORS_ORIGIN=https://preprod-pregen.netlify.app/,https://pregen.netlify.app
CORS_ORIGIN=
CORS_ALLOWED_ORIGINS=

# Auth and session secrets
JWT_SECRET=replace-with-a-long-random-secret
SESSION_SECRET=replace-with-a-different-long-random-secret
REFRESH_TOKEN_EXPIRES_IN=30d
GEMINI_API_KEY=replace-with-your-gemini-api-key

# Primary Mongo connection
MONGO_URL=mongodb+srv://<username>:<password>@<cluster-host>/?retryWrites=true&w=majority
MONGO_DB_NAME=pregen_lms

# Optional Atlas direct-host fallback for local verification
# Use this only when SRV lookup fails on your machine but the Atlas shard hosts
# are reachable over TCP 27017. Replace MONGO_URL with the resolved direct-host
# replica-set URI temporarily; do not commit real credentials.
# Example:
# MONGO_URL=mongodb://<username>:<password>@<host-00>:27017,<host-01>:27017,<host-02>:27017/?tls=true&authSource=admin&replicaSet=<replica-set-name>&appName=Cluster0

# Optional Mongo startup tuning
MONGO_CONNECT_TIMEOUT_MS=10000
MONGO_SERVER_SELECTION_TIMEOUT_MS=10000
MONGO_SOCKET_TIMEOUT_MS=20000
MONGO_RETRY_ATTEMPTS=1
MONGO_RETRY_DELAY_MS=1500

# Optional explicit local-dev fallback
# Only used when NODE_ENV is not production and MONGO_USE_LOCAL_FALLBACK=true.
MONGO_USE_LOCAL_FALLBACK=false
MONGO_LOCAL_URL=mongodb://127.0.0.1:27017/pregen_lms_dev

# AI / FastAPI service URL
# Local dev default: http://localhost:8000
# Production: https://pregen-xce4.onrender.com
AI_SERVICE_URL=https://pregen-xce4.onrender.com
REDIS_URL=
