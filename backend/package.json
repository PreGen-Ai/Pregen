{
  "name": "backend",
  "version": "1.0.0",
  "description": "AI-Assisted E-Learning Backend (Express + MongoDB)",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "doctor": "node scripts/doctor.mjs",
    "seed": "node src/seeds/seed.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --config jest.config.cjs",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/jest --config jest.config.cjs --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --config jest.config.cjs --coverage",
    "test:ci": "node --experimental-vm-modules node_modules/.bin/jest --config jest.config.cjs --ci --forceExit"
  },
  "dependencies": {
    "axios": "^1.12.2",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "connect-mongodb-session": "^3.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^7.5.1",
    "express-session": "^1.18.2",
    "express-validator": "^7.2.1",
    "helmet": "^7.2.0",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "katex": "^0.16.28",
    "mammoth": "^1.11.0",
    "mongodb": "^7.1.0",
    "mongoose": "^8.22.1",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "node-binance-api": "^1.0.17",
    "node-cron": "^4.2.1",
    "path": "^0.12.7",
    "rate-limit": "^0.1.0",
    "react-markdown": "^10.1.0",
    "redis": "^5.10.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "sentiment": "^5.0.2",
    "swagger-ui-express": "^5.0.1",
    "textract": "^2.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "nodemon": "^3.1.10",
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.1.2",
    "supertest": "^7.0.0"
  }
}
