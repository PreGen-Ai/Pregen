# FastAPI AI service
ENVIRONMENT=development
PORT=8000

# Provider selection
PRIMARY_LLM_PROVIDER=openai
FALLBACK_LLM_PROVIDER=gemini

# OpenAI primary provider
OPENAI_API_KEY=replace-with-your-openai-api-key
OPENAI_MODEL=gpt-5.4-mini

# Gemini fallback provider
GEMINI_API_KEY=replace-with-your-gemini-api-key
GEMINI_FALLBACK_MODEL=gemini-2.5-flash

# Internal bridge auth shared with backend AI_SERVICE_SHARED_SECRET
AI_SERVICE_SHARED_SECRET=dev-ai-service-secret

# Optional Mongo analytics persistence
DISABLE_MONGO=true
MONGODB_URI=
MONGODB_DB_NAME=pregen_lms
