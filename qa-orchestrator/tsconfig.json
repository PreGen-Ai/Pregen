{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node", "cypress"]
  },
  "include": [
    "playwright.config.ts",
    "cypress.config.ts",
    "tests/playwright/**/*.ts",
    "cypress/e2e/**/*.ts"
  ]
}
