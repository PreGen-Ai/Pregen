# Copy to .env.load and fill in values before running
# Usage: k6 run --env-file .env.load k6/run.js

# ── Required ─────────────────────────────────────────────────────────────────
BASE_URL=http://localhost:5000
SA_EMAIL=mohamedhammad3.142@gmail.com
SA_PASSWORD=12345678

# ── Load stage ───────────────────────────────────────────────────────────────
# A  = baseline  (100 VUs)
# B  = moderate  (500 VUs)
# C  = peak      (1500 VUs)
# D  = spike     (3000 VUs)
# E  = soak      (300 VUs × 4 h)
# storm = submission storm (1000 VUs, short burst)
STAGE=A

# ── Data seeding ─────────────────────────────────────────────────────────────
TENANT_COUNT=500
STUDENTS_PER=300
TEACHERS_PER=20
CLASSES_PER=10
ASSIGNMENTS_PER=50  
TEST_PASSWORD=12345678

# ── AI stub ──────────────────────────────────────────────────────────────────
# Set to true to skip real AI provider calls during load tests.
# Only set false for Mode B (real AI throttled) runs with a small VU count.
STUB_AI=true

# ── Single scenario ───────────────────────────────────────────────────────────
# Uncomment to run only one scenario (1–6). Omit for all.
# SCENARIO=5
